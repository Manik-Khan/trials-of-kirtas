    "features": [
      {
        "desc": "Curse a creature within 30 ft as a bonus action. Gain bonus to damage, crit on 19-20, regain HP on kill.",
        "name": "Hexblade's Curse",
        "source": "The Hexblade"
      },
      {
        "desc": "Proficiency with medium armor, shields, and martial weapons. Use CHA for attack/damage with one weapon.",
        "name": "Hex Warrior",
        "source": "The Hexblade"
      },
      {
        "desc": "Gained two invocations at level 2.",
        "name": "Eldritch Invocations",
        "source": "Warlock"
      },
      {
        "desc": "Add CHA modifier (+3) to Eldritch Blast damage.",
        "name": "Eldritch Invocation: Agonizing Blast",
        "source": "Warlock"
      },
      {
        "desc": "Push targets 10 ft away on Eldritch Blast hit.",
        "name": "Eldritch Invocation: Repelling Blast",
        "source": "Warlock"
      },
      {
        "desc": "Darkvision 120 ft. Can cast Darkness using a spell slot.",
        "name": "Eyes of the Dark",
        "source": "Shadow Magic"
      },
      {
        "desc": "When reduced to 0 HP, make CHA save to drop to 1 HP instead.",
        "name": "Strength of the Grave",
        "source": "Shadow Magic"
      },
      {
        "desc": "Advantage on saves against being charmed. Cannot be magically put to sleep.",
        "name": "Fey Ancestry",
        "source": "Astral Elf"
      },
      {
        "desc": "Teleport up to 30 ft as a bonus action. Uses = proficiency bonus per long rest.",
        "name": "Starlight Step",
        "source": "Astral Elf"
      },
      {
        "desc": "Trance for 4 hours instead of sleep. Gain a weapon or tool proficiency each trance.",
        "name": "Astral Trance",
        "source": "Astral Elf"
      },
      {
        "desc": "Secure free passage on ships for your party.",
        "name": "Ship's Passage",
        "source": "Captain"
      }
    ],
